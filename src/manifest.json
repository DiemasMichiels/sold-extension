{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "chromium:manifest_version": 3,
  "firefox:manifest_version": 3,
  "version": "1.3.0",
  "name": "Sold!",
  "description": "A house price guessing game. Browse real estate listings with hidden prices and test your pricing instincts!",
  "icons": {
    "16": "images/icon.png",
    "32": "images/icon.png",
    "48": "images/icon.png",
    "64": "images/icon.png",
    "128": "images/icon.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": "images/icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.immoweb.be/*",
        "*://*.funda.nl/*",
        "*://*.rightmove.co.uk/*",
        "*://*.zillow.com/*",
        "*://*.finn.no/*",
        "*://*.realestate.com.au/*",
        "*://*.realestate.co.nz/*",
        "*://*.propertypal.com/*"
      ],
      "js": ["./content/index.tsx"],
      "run_at": "document_start"
    }
  ],
  "author": "Diemas Michiels",
  "permissions": ["storage"],
  "firefox:browser_specific_settings": {
    "gecko": {
      "id": "sold-extension@diemas.dev",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
